# Serial console configuration
console=ttyS2,115200n8
bootdelay=0

# Kernel and DTB load addresses
kernel_addr=0x83000000
fdt_addr=0x82000000

# Network configuration for TFTP/NFS boot
ipaddr=192.168.1.81
serverip=192.168.1.1
netmask=255.255.255.0
gatewayip=192.168.1.1

# NFS configuration (for debugging)
nfsroot=/srv/nfs/rootfs
nfsopts=nolock,v3,tcp

# PHY auto-negotiation timeout (in milliseconds, default 4000)
# Set to 0 to skip auto-negotiation wait if link is already up
phy_aneg_timeout=4000

# Default bootargs for kernel boot
# earlycon for early boot messages, console for normal operation (both on ttyS2)
bootargs=console=${console} earlycon=ns16550a,mmio32,0x02800000 rw

# NFS bootargs setup (overrides default bootargs)
args_nfs=setenv bootargs console=${console} earlycon=ns16550a,mmio32,0x02800000 root=/dev/nfs rw nfsroot=${serverip}:${nfsroot},${nfsopts} ip=${ipaddr}:${serverip}:${gatewayip}:${netmask}::eth0:off

# TFTP boot: Load Image and DTB separately from TFTP server
# Use a single TFTP session to reduce PHY re-initialization
get_kernel_tftp=tftp ${kernel_addr} Image
get_fdt_tftp=tftp ${fdt_addr} k3-am625-sk.dtb
boot_tftp=if run get_kernel_tftp && run get_fdt_tftp; then booti ${kernel_addr} - ${fdt_addr}; fi

# MMC boot: Load FIT_Image.bin from SD card
boot_mmc=bootk

# Boot order control:
# 1. Check boot_from_nfs - if set, configure NFS bootargs
# 2. Check boot_from_tftp - if set, load kernel from TFTP
# 3. Default: load kernel from MMC
bootcmd=if test "${boot_from_nfs}" = "1"; then run args_nfs; fi; if test "${boot_from_tftp}" = "1"; then run boot_tftp; else run boot_mmc; fi